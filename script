        timerLabel.Text = string.format("%02d:%02d", mins, secs)
        titleText.Text = "SWILL RIVALS HUB [" .. string.format("%02d:%02d", mins, secs) .. "]"
        wait(1)
    end
    if trialActive then permanentLock() end
end)

