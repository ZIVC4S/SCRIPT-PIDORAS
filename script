            if n:find("kill") then kills = v.Value or 0 end
            if n:find("death") then deaths = v.Value or 0 end
        end
        local kd = deaths > 0 and string.format("%.2f", kills / deaths) or tostring(kills)
        statsDisplay.Text = "🗡️ KILLS: " .. kills .. "\n💀 DEATHS: " .. deaths .. "\n📊 K/D: " .. kd
    else
        statsDisplay.Text = "🗡️ KILLS: --\n💀 DEATHS: --\n📊 K/D: --"
    end
end
